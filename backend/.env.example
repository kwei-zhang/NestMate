# Database
DATABASE_URL=postgresql+psycopg://nestmate:nestmate@localhost:5432/nestmate

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=30

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# OAuth — base used to build redirect URIs, e.g. http://localhost:8000
OAUTH_REDIRECT_BASE=http://localhost:8000
FRONTEND_BASE=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WeChat website app (开放平台网站应用) OAuth
WECHAT_APPID=
WECHAT_SECRET=

# Comma-separated provider_ids or emails granted admin role on first login
ADMIN_EMAILS=
